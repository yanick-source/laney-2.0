# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# URL of your deployed React frontend (Vercel)
FRONTEND_URL=https://your-app.vercel.app

# URL of this backend server (Railway / Render / etc.)
BACKEND_URL=https://your-print-server.railway.app

# ── SFTP (Option A: upload files directly to the printer's server) ────────────
SFTP_HOST=printer-server.com
SFTP_PORT=22
SFTP_USERNAME=your_sftp_username
SFTP_PASSWORD=your_sftp_password
# OR use a base64-encoded private key instead of password:
# SFTP_PRIVATE_KEY=<base64 of your id_rsa file: `base64 -i ~/.ssh/id_rsa`>
SFTP_REMOTE_PATH=/incoming

# ── Webhook (Option B: POST manifest + base64 PDFs to a print API URL) ───────
# Leave empty if using SFTP. If set, SFTP is skipped and this URL is called.
PRINT_WEBHOOK_URL=
